#include <iostream>
#include <limits>
using namespace std;

class Bank {
private:
    string name;
    int accNo;
    float balance;

public:
    void createAccount() {
        cout << "Enter Name: ";
        cin >> name;

        cout << "Enter Account Number: ";
        cin >> accNo;

        cout << "Enter Initial Balance: ";
        cin >> balance;
    }

    void deposit() {
        float amt;
        cout << "Enter Deposit Amount: ";
        cin >> amt;

        if (amt > 0) {
            balance += amt;
            cout << "Amount Deposited Successfully!\n";
        } else {
            cout << "Invalid Amount!\n";
        }
    }

    void withdraw() {
        float amt;
        cout << "Enter Withdrawal Amount: ";
        cin >> amt;

        if (amt <= 0) {
            cout << "Invalid Amount!\n";
        }
        else if (amt <= balance) {
            balance -= amt;
            cout << "Withdrawal Successful!\n";
        }
        else {
            cout << "Insufficient Balance!\n";
        }
    }

    void display() {
        cout << "\n------ Account Details ------\n";
        cout << "Name           : " << name << endl;
        cout << "Account Number : " << accNo << endl;
        cout << "Balance        : " << balance << endl;
    }
};

int main() {
    Bank b;
    int choice;

    b.createAccount();

    while (true) {
        cout << "\n========== BANK MENU ==========\n";
        cout << "1. Deposit\n";
        cout << "2. Withdraw\n";
        cout << "3. Display Account\n";
        cout << "4. Exit\n";
        cout << "Enter Choice: ";

        cin >> choice;

        if (cin.fail()) {
            cin.clear();
            cin.ignore(numeric_limits<streamsize>::max(), '\n');
            cout << "Invalid Input! Please enter a number.\n";
            continue;
        }

        switch (choice) {
            case 1:
                b.deposit();
                break;

            case 2:
                b.withdraw();
                break;

            case 3:
                b.display();
                break;

            case 4:
                cout << "\nThank You! Program Ended Successfully.\n";
                return 0;

            default:
                cout << "Invalid Choice! Try Again.\n";
        }
    }

    return 0;
}
